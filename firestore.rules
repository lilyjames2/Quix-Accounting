rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Helper functions
    function isAuthenticated() {
      return request.auth != null;
    }
    function isOwner(uid) {
      return isAuthenticated() && request.auth.uid == uid;
    }
    function isValidTransaction(data) {
      return data.type in ['income', 'expense'] &&
             data.amount is number && data.amount >= 0 &&
             data.category is string && data.category.size() > 0 &&
             data.date is string &&
             data.uid == request.auth.uid;
    }
    function isValidEmployee(data) {
      return data.name is string && data.name.size() > 0 &&
             data.position is string && data.position.size() > 0 &&
             data.salary is number && data.salary >= 0 &&
             data.uid == request.auth.uid;
    }
    function isValidAttendance(data) {
      return data.employeeId is string &&
             data.date is string &&
             data.status in ['present', 'absent', 'late'] &&
             data.uid == request.auth.uid;
    }
    function isValidNote(data) {
      return data.title is string && data.title.size() > 0 &&
             data.content is string &&
             data.timestamp is string &&
             data.uid == request.auth.uid;
    }

    match /transactions/{id} {
      allow read: if isOwner(resource.data.uid);
      allow create: if isAuthenticated() && isValidTransaction(request.resource.data);
      allow update: if isOwner(resource.data.uid) && isValidTransaction(request.resource.data);
      allow delete: if isOwner(resource.data.uid);
    }

    match /employees/{id} {
      allow read: if isOwner(resource.data.uid);
      allow create: if isAuthenticated() && isValidEmployee(request.resource.data);
      allow update: if isOwner(resource.data.uid) && isValidEmployee(request.resource.data);
      allow delete: if isOwner(resource.data.uid);
    }

    match /attendance/{id} {
      allow read: if isOwner(resource.data.uid);
      allow create: if isAuthenticated() && isValidAttendance(request.resource.data);
      allow update: if isOwner(resource.data.uid) && isValidAttendance(request.resource.data);
      allow delete: if isOwner(resource.data.uid);
    }

    match /notes/{id} {
      allow read: if isOwner(resource.data.uid);
      allow create: if isAuthenticated() && isValidNote(request.resource.data);
      allow update: if isOwner(resource.data.uid) && isValidNote(request.resource.data);
      allow delete: if isOwner(resource.data.uid);
    }
  }
}
