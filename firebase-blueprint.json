{
  "entities": {
    "Transaction": {
      "title": "Transaction",
      "description": "Income or expense entry",
      "type": "object",
      "properties": {
        "type": { "type": "string", "enum": ["income", "expense"] },
        "amount": { "type": "number" },
        "category": { "type": "string" },
        "description": { "type": "string" },
        "date": { "type": "string", "format": "date-time" },
        "uid": { "type": "string" }
      },
      "required": ["type", "amount", "category", "date", "uid"]
    },
    "Employee": {
      "title": "Employee",
      "description": "Office employee details",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "position": { "type": "string" },
        "salary": { "type": "number" },
        "contact": { "type": "string" },
        "uid": { "type": "string" }
      },
      "required": ["name", "position", "salary", "uid"]
    },
    "Attendance": {
      "title": "Attendance",
      "description": "Daily attendance record",
      "type": "object",
      "properties": {
        "employeeId": { "type": "string" },
        "date": { "type": "string", "format": "date" },
        "status": { "type": "string", "enum": ["present", "absent", "late"] },
        "uid": { "type": "string" }
      },
      "required": ["employeeId", "date", "status", "uid"]
    },
    "Note": {
      "title": "Note",
      "description": "Office notes and logs",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "content": { "type": "string" },
        "timestamp": { "type": "string", "format": "date-time" },
        "uid": { "type": "string" }
      },
      "required": ["title", "content", "timestamp", "uid"]
    }
  },
  "firestore": {
    "/transactions": { "schema": "Transaction", "description": "Financial transactions" },
    "/employees": { "schema": "Employee", "description": "Employee records" },
    "/attendance": { "schema": "Attendance", "description": "Attendance tracking" },
    "/notes": { "schema": "Note", "description": "Office notes" }
  }
}
